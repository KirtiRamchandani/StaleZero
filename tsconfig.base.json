{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@stalezero/core": ["./packages/core/src/index.ts"],
      "stalezero": ["./packages/stalezero/src/index.ts"],
      "@stalezero/memory": ["./packages/adapters/memory/src/index.ts"],
      "@stalezero/redis": ["./packages/adapters/redis/src/index.ts"],
      "@stalezero/redux": ["./packages/adapters/redux/src/index.ts"],
      "@stalezero/react-query": ["./packages/adapters/react-query/src/index.ts"],
      "@stalezero/rtk-query": ["./packages/adapters/rtk-query/src/index.ts"],
      "@stalezero/swr": ["./packages/adapters/swr/src/index.ts"],
      "@stalezero/trpc": ["./packages/adapters/trpc/src/index.ts"],
      "@stalezero/zustand": ["./packages/adapters/zustand/src/index.ts"],
      "@stalezero/next": ["./packages/adapters/next/src/index.ts"],
      "@stalezero/apollo": ["./packages/adapters/apollo/src/index.ts"],
      "@stalezero/graphql": ["./packages/adapters/graphql/src/index.ts"],
      "@stalezero/cloudflare-kv": ["./packages/adapters/cloudflare-kv/src/index.ts"],
      "@stalezero/websocket": ["./packages/adapters/websocket/src/index.ts"],
      "@stalezero/search": ["./packages/adapters/search/src/index.ts"],
      "@stalezero/http": ["./packages/adapters/http/src/index.ts"],
      "@stalezero/memory-bus": ["./packages/bus/memory/src/index.ts"],
      "@stalezero/redis-bus": ["./packages/bus/redis/src/index.ts"],
      "@stalezero/postgres-bus": ["./packages/bus/postgres/src/index.ts"],
      "@stalezero/http-bus": ["./packages/bus/http/src/index.ts"],
      "@stalezero/kafka-bus": ["./packages/bus/kafka/src/index.ts"],
      "@stalezero/nats-bus": ["./packages/bus/nats/src/index.ts"],
      "@stalezero/testing": ["./packages/testing/src/index.ts"],
      "@stalezero/devtools": ["./packages/devtools/src/index.ts"],
      "@stalezero/otel": ["./packages/otel/src/index.ts"],
      "@stalezero/snapshot": ["./packages/snapshot/src/index.ts"],
      "@stalezero/github-action": ["./packages/github-action/src/index.ts"],
      "@stalezero/recipes": ["./packages/recipes/src/index.ts"],
      "@stalezero/pack-saas": ["./packages/pack-saas/src/index.ts"],
      "@stalezero/pack-commerce": ["./packages/pack-commerce/src/index.ts"],
      "@stalezero/pack-auth": ["./packages/pack-auth/src/index.ts"]
    }
  },
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/type-inference.ts", "dist", "node_modules", ".pack", "reports"]
}
