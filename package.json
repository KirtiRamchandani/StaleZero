{
  "name": "stalezero-repo",
  "version": "0.1.0",
  "private": true,
  "description": "Mutation consequence engine for cache invalidation, state sync, receipts, and devtools.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KirtiRamchandani/StaleZero.git"
  },
  "bugs": {
    "url": "https://github.com/KirtiRamchandani/StaleZero/issues"
  },
  "homepage": "https://github.com/KirtiRamchandani/StaleZero#readme",
  "keywords": [
    "cache",
    "invalidation",
    "typescript",
    "redis",
    "react-query",
    "swr",
    "nextjs",
    "devtools",
    "opentelemetry",
    "state-management"
  ],
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/core",
    "packages/stalezero",
    "packages/adapters/*",
    "packages/bus/*",
    "packages/testing",
    "packages/cli",
    "packages/devtools",
    "packages/otel",
    "packages/create-stalezero-adapter-template",
    "packages/snapshot",
    "packages/github-action",
    "packages/recipes",
    "packages/pack-saas",
    "packages/pack-commerce",
    "packages/pack-auth"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false && npm run typecheck:public-api",
    "typecheck:public-api": "tsc --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --strict --skipLibCheck packages/core/src/type-inference.ts",
    "test": "vitest run",
    "clean": "node ./scripts/clean.mjs",
    "check": "npm run typecheck && npm run test",
    "metadata:prepare": "node ./scripts/prepare-package-metadata.mjs",
    "verify:clean-clone": "node ./scripts/clean-clone-verify.mjs",
    "verify:pack": "node ./scripts/pack-verify.mjs",
    "verify:consumer": "node ./scripts/consumer-smoke.mjs",
    "verify:cli": "node ./scripts/cli-smoke.mjs",
    "verify:examples": "node ./scripts/run-examples.mjs",
    "verify:template": "node ./scripts/template-smoke.mjs",
    "verify:adapters": "node ./scripts/adapter-conformance.mjs",
    "verify:api": "node ./scripts/api-report.mjs && node ./scripts/api-snapshot-check.mjs",
    "verify:graph": "node ./scripts/package-graph.mjs",
    "verify:security": "node ./scripts/security-report.mjs",
    "verify:licenses": "node ./scripts/license-report.mjs",
    "benchmark": "node ./scripts/benchmark.mjs",
    "release:dry-run": "node ./scripts/release-dry-run.mjs",
    "example:minimal": "node ./scripts/run-examples.mjs --only=minimal-node",
    "example:next": "node ./scripts/run-examples.mjs --only=next-react-query-redis",
    "example:ecommerce": "node ./scripts/run-examples.mjs --only=ecommerce-demo",
    "example:redis-streams": "node ./scripts/run-examples.mjs --only=redis-streams",
    "example:swr": "node ./scripts/run-examples.mjs --only=swr",
    "example:redux": "node ./scripts/run-examples.mjs --only=redux-toolkit",
    "example:zustand": "node ./scripts/run-examples.mjs --only=zustand",
    "example:websocket": "node ./scripts/run-examples.mjs --only=websocket-notification",
    "example:search": "node ./scripts/run-examples.mjs --only=search-reindex",
    "example:http-bus": "node ./scripts/run-examples.mjs --only=http-webhook-bus",
    "example:dogfood": "npm run build && node ./examples/dogfood-app/run.mjs",
    "verify:rc": "npm run metadata:prepare && npm install && npm run clean && npm run build && npm run check && npm run verify:api && npm run verify:graph && npm run verify:adapters && npm run verify:pack && npm run verify:consumer && npm run verify:cli && npm run verify:examples && npm run verify:template && npm run benchmark && npm run verify:security && npm run verify:licenses && npm run release:dry-run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
