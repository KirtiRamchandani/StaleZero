      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stalezero/core": "0.1.0",
    "@stalezero/memory": "0.1.0",
    "@stalezero/redis": "0.1.0",
