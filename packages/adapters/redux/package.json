{
  "name": "@stalezero/redux",
  "version": "0.1.0",
  "description": "Redux adapter and reducer helpers for StaleZero.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stalezero/core": "0.1.0"
  },
  "peerDependencies": {
    "redux": ">=4 || >=5",
    "@reduxjs/toolkit": ">=1.9"
  },
  "peerDependenciesMeta": {
    "redux": {
      "optional": true
    },
    "@reduxjs/toolkit": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stalezero/stalezero.git"
  },
  "bugs": {
    "url": "https://github.com/stalezero/stalezero/issues"
  },
  "homepage": "https://github.com/stalezero/stalezero#readme",
  "keywords": [
    "cache",
    "invalidation",
    "typescript",
    "javascript",
    "state",
    "redis",
    "react-query",
    "swr",
    "nextjs"
  ],
  "engines": {
    "node": ">=20"
  }
}
