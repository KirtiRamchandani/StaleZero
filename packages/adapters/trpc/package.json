{
  "name": "@stalezero/trpc",
  "version": "0.1.0",
  "description": "tRPC query utility adapter for StaleZero.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stalezero/core": "0.1.0"
  },
  "peerDependencies": {
    "@trpc/client": ">=10 || >=11",
    "@trpc/react-query": ">=10 || >=11"
  },
  "peerDependenciesMeta": {
    "@trpc/client": {
      "optional": true
    },
    "@trpc/react-query": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stalezero/stalezero.git"
  },
  "bugs": {
    "url": "https://github.com/stalezero/stalezero/issues"
  },
  "homepage": "https://github.com/stalezero/stalezero#readme",
  "keywords": [
    "cache",
    "invalidation",
    "typescript",
    "javascript",
    "state",
    "redis",
    "react-query",
    "swr",
    "nextjs"
  ],
  "engines": {
    "node": ">=20"
  }
}
