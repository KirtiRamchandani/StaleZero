{
  "name": "@stalezero/zustand",
  "version": "0.1.0",
  "description": "Zustand adapter for StaleZero.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@stalezero/core": "0.1.0"
  },
  "peerDependencies": {
    "zustand": ">=4 || >=5"
  },
  "peerDependenciesMeta": {
    "zustand": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KirtiRamchandani/StaleZero.git"
  },
  "bugs": {
    "url": "https://github.com/KirtiRamchandani/StaleZero/issues"
  },
  "homepage": "https://github.com/KirtiRamchandani/StaleZero#readme",
  "keywords": [
    "cache",
    "invalidation",
    "typescript",
    "javascript",
    "state",
    "redis",
    "react-query",
    "swr",
    "nextjs",
    "mutation",
    "devtools",
    "opentelemetry"
  ],
  "engines": {
    "node": ">=20"
  }
}
